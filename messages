<!DOCTYPE html>
<html>
<head>
  <title>Messages</title>
  <style>
    body { 
      font-family: sans-serif; 
      max-width: 600px; 
      margin: 40px auto; 
      line-height: 1.5;
    }
    .msg { 
      padding: 15px; 
      border: 1px solid #ddd; 
      margin-bottom: 15px; 
      border-radius: 8px; 
      background: #fafafa;
    }
    .date { 
      font-size: 12px; 
      color: #666; 
      margin-bottom: 8px; 
    }
  </style>
</head>
<body>
  <h1>Messages</h1>
  <div id="messages">Loading…</div>

  <script>
    fetch("/messages")
      .then(r => r.json())
      .then(list => {
        const container = document.getElementById("messages");
        container.innerHTML = "";

        list.forEach(m => {
          const div = document.createElement("div");
          div.className = "msg";
          div.innerHTML = `
            <div class="date">${m.created_at}</div>
            <strong>${m.name}</strong> (${m.email})<br><br>
            ${m.message}
          `;
          container.appendChild(div);
        });
      })
      .catch(err => {
        document.getElementById("messages").innerText = "Error loading messages.";
      });
  </script>
</body>
</html>
